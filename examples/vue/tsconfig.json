{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "paths": {
      "@sqren/docx-editor-vue": ["../../packages/vue/src/index.ts"],
      "@sqren/docx-editor-core": ["../../packages/core/src/core.ts"],
      "@sqren/docx-editor-core/*": ["../../packages/core/src/*"]
    }
  },
  "include": ["src"]
}
