{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "declaration": true,
    "declarationMap": true,
    "baseUrl": ".",
    "paths": {
      "@valent/docx-editor-vue": ["../vue/src/index.ts"],
      "@valent/docx-editor-core": ["../core/src/core.ts"],
      "@valent/docx-editor-core/*": ["../core/src/*"],
      "@valent/docx-editor-agents/bridge": ["../agents/src/bridge.ts"],
      "@valent/docx-editor-agents/vue": ["../agents/src/vue.ts"],
      "@valent/docx-editor-i18n": ["../i18n/src/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
