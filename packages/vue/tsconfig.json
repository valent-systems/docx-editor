{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "declaration": true,
    "declarationMap": true,
    "baseUrl": ".",
    "paths": {
      "@sqren/docx-editor-core": ["../core/src/core.ts"],
      "@sqren/docx-editor-core/*": ["../core/src/*"],
      "@sqren/docx-editor-agents/bridge": ["../agents/src/bridge.ts"],
      "@sqren/docx-editor-agents/vue": ["../agents/src/vue.ts"],
      "@sqren/docx-editor-i18n": ["../i18n/src/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
